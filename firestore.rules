rules_version = '2';

// ─── Mi Concierge — Firestore Security Rules ────────────────────────────────
//
// Security model:
//   • Guests (unauthenticated):
//       - Read hotels (needed to load hotel profile on first visit)
//       - Read + create shared_itineraries (share links)
//       - Create analytics_events (fire-and-forget tracking)
//       - Create onboarding_requests (hotel signup form)
//       - NO write access to hotels, rate_limits, or cached_itineraries
//
//   • Admin (Firebase Admin SDK via Vercel):
//       - Bypasses ALL rules automatically — no rules needed for admin operations
//       - Hotel CRUD, analytics reads/deletes, onboarding reads all use Admin SDK
//       - Authenticated via HMAC session token in /api/admin-data.js
//
//   • rate_limits + cached_itineraries:
//       - Server-only (Admin SDK) — all client access denied
// ────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // Hotels — guests read-only; all writes via Admin SDK (api/admin-data.js)
    match /hotels/{hotelId} {
      allow read: if true;
      allow write: if false;
    }

    // Shared itineraries — guests can create share links and load them
    match /shared_itineraries/{docId} {
      allow read, create: if true;
      allow update, delete: if false;
    }

    // Analytics — guests can log events; reads and deletes are admin-only (Admin SDK)
    match /analytics_events/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Onboarding requests — hotels can submit the form; reads/updates are admin-only
    match /onboarding_requests/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Rate limits — server-only; no client access
    match /rate_limits/{docId} {
      allow read, write: if false;
    }

    // Cached itineraries — server-only; no client access
    match /cached_itineraries/{docId} {
      allow read, write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
